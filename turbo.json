{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "SUPABASE_URL", 
        "SUPABASE_KEY", 
        "PUBLIC_SUPABASE_URL", 
        "PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_FONOTECA_SUPABASE_URL",
        "NEXT_PUBLIC_FONOTECA_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_BIO_INTRANET_SUPABASE_URL",
        "NEXT_PUBLIC_BIO_INTRANET_SUPABASE_ANON_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".vercel/output/**", ".next/**", "!.next/cache/**"]
    },


    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
