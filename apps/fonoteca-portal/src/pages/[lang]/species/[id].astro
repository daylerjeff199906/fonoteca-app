---
import Layout from "../../../layouts/Layout.astro";
import { Header } from "../../../components/react/Header";
import { Footer } from "../../../components/react/Footer";
import { SpeciesDetailClient } from "../../../components/react/SpeciesDetailClient";
import { translations, LANGUAGES } from "../../../i18n/data";
import { getSpeciesById } from "../../../data/species";
import logoIiap from "../../../assets/logo_iiap.png";

export const prerender = false;


const lang = Astro.params.lang || 'es';
const id = Astro.params.id;
const content = translations[lang as keyof typeof translations];

if (!content) {
    return Astro.redirect("/es/");
}

const species = id ? await getSpeciesById(id) : null;
const commonName = species ? (species[`commonName_${lang}` as keyof typeof species] || species.commonName_es) : '';
const pageTitle = species
    ? `${species.scientificName}${commonName ? ` (${commonName})` : ''} | Fonoteca`
    : content.nav.library;

const pageDescription = species
    ? `Detalles, audios, cantos, espectrogramas y distribución de ${species.scientificName} en la Amazonía peruana. Registrado en ${species.location || 'Perú'}.`
    : "Biblioteca acústica de fauna amazónica - Fonoteca";

const pageImage = species?.mainImage || "/og-image.jpg";
---

<Layout title={pageTitle} lang={lang} description={pageDescription} image={pageImage}>
    <Header
        client:only="react"
        content={content.nav}
        logoSrc={logoIiap.src}
        lang={lang}
    />

    <div class="min-h-screen">
        <SpeciesDetailClient client:only="react" id={id!} lang={lang} />
    </div>

    <Footer content={content.footer} logoSrc={logoIiap.src} />
</Layout>
